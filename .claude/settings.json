{
  "permissions": {
    "allow": [
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[harness] 変更前にファイルの現在状態を確認しましたか？ Read してから Edit してください'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(rm -rf|git reset --hard|git push --force|git checkout -- \\.)'; then echo 'BLOCKED: 破壊的コマンドを検出しました。本当に実行しますか？' && exit 2; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "長門有希",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "~/.kube",
        "/tmp"
      ],
      "allowRead": [
        "~/Documents"
      ]
    }
  },
  "alwaysThinkingEnabled": true
}
